# ===================================
# EconoQuest Environment Variables
# ===================================
# Copy this file to .env.local and fill in your actual values

# ===== Authentication Service =====
# Client-side auth service URL (exposed to browser)
NEXT_PUBLIC_AUTH_SERVICE_URL=

# Server-side auth service URL (private, more secure)
AUTH_SERVICE_URL=

# ===== Backend Proxy Layer =====
# Public proxy layer URL (exposed to browser)
NEXT_PUBLIC_PROXY_URL=

# ===== Supabase Configuration =====
# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (private, server-side only)
# WARNING: Keep this secret! Never expose in client code.
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ===== Internal Authentication =====
# Internal token for securing backend requests
# Must match the token expected by your backend service
INTERNAL_TOKEN=your_internal_token_here